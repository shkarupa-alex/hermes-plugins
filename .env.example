# Development-only live test credential. Do not commit the real value.
# A normal installation stores this in the active Hermes profile via
# `hermes gateway setup` (VK Community) or `hermes vk setup`.
VK_COMMUNITY_TOKEN=<VK_COMMUNITY_ACCESS_TOKEN>

# group_id and the private formatting-probe peer ID are non-secret numeric
# configuration values; put group_id in config.yaml and pass the peer ID via
# `hermes vk probe-formatting --peer-id <ID>`.
